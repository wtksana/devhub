{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "devhub",
  "version": "0.1.0",
  "identifier": "com.ttat.devhub",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "devhub",
        "width": 1280,
        "height": 720,
        "decorations": false,
        "visible": false,
        "backgroundColor": "#282c34"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
